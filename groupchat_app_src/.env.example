# --- Web Chat App Configuration ---
# MySQL DSN (Async): mysql+asyncmy://USER:PASS@HOST:PORT/DBNAME
DATABASE_URL=mysql+asyncmy://chatuser:chatpass@localhost:3306/groupchat

# JWT secret for signing access tokens (set to a long random string!)
JWT_SECRET=please_change_me_to_a_long_random_value
# Token expiration in minutes (default: 43200 = 30 days)
JWT_EXPIRE_MINUTES=43200

# Offline Llama 3.
# Recommended: run a local llama.cpp server or vLLM OpenAI-compatible endpoint.
LLM_PROVIDER=llama_cpp_server
LLM_API_BASE=http://localhost:8001/v1
LLM_MODEL=llama-3-8b-instruct
# Optional API key if your server enforces one
LLM_API_KEY=

# Optional direct GGUF mode:
# 1. pip install llama-cpp-python
# 2. Set LLM_PROVIDER=llama_cpp
# 3. Set LLAMA_MODEL_PATH to your local Llama 3 .gguf model
LLAMA_MODEL_PATH=
LLAMA_N_CTX=4096
LLAMA_N_GPU_LAYERS=-1

# Host/Port for the FastAPI app
APP_HOST=0.0.0.0
APP_PORT=8000
